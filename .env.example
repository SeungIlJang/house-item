# ===== 집안의모든것(home-items) 환경 변수 예시 =====
# 실제 값은 .env 파일에 넣고, .env 는 git에 커밋하지 않습니다.
# 이 파일(.env.example)은 "어떤 값이 필요한지" 알려주는 견본입니다.

# ---- Backend (FastAPI) ----
# 애플리케이션 환경: development | production
APP_ENV=development

# 데이터베이스 연결 (로컬 PostgreSQL 사용)
# 형식: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
# 로컬 개발용 전용 계정. 운영에서는 별도 강력한 비밀번호로 교체.
DATABASE_URL=postgresql+psycopg://home_items:home_items_dev_pw@localhost:5432/home_items

# JWT (로그인 토큰) 비밀키 — 운영에서는 반드시 길고 무작위한 값으로 교체
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS 허용 출처 (쉼표로 구분). 프론트 개발 서버 주소
# 개발 환경에서는 localhost/127.0.0.1 의 모든 포트가 자동 허용됩니다(코드의 정규식).
# 운영 환경에서는 이 목록만 허용되므로 실제 도메인을 넣으세요.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8100

# ---- 이미지 저장 ----
# local = 서버 디스크(개발/단일 서버), s3 = S3/R2 오브젝트 스토리지(운영 권장)
STORAGE_BACKEND=local

# local 일 때: 이미지 업로드 저장 경로
UPLOAD_DIR=uploads

# s3(=Cloudflare R2 포함) 일 때 채우기
# R2 대시보드 → R2 → 버킷 생성 → "Manage R2 API Tokens" 로 키 발급
S3_ENDPOINT_URL=            # 예: https://<accountid>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=                  # 예: home-items
S3_REGION=auto
S3_PUBLIC_BASE_URL=         # 공개 URL 예: https://pub-xxxxxxxx.r2.dev (또는 연결한 커스텀 도메인)

# ---- Frontend (Ionic Vue) — 14단계에서 사용 ----
# VITE_API_BASE_URL=http://localhost:8000/api/v1
